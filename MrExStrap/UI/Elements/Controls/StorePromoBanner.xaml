<UserControl x:Class="ExploitStrap.UI.Elements.Controls.StorePromoBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:ExploitStrap.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="760">
    <!-- Reusable rsware.store plug. Whole card is clickable; the Shop now button is the explicit CTA. -->
    <Border Margin="0,0,0,12" Padding="16,12" CornerRadius="8" Cursor="Hand" ToolTip="https://rsware.store/"
            Background="{StaticResource BrandSurfaceBrush}" BorderThickness="1">
        <Border.BorderBrush>
            <SolidColorBrush Color="{StaticResource BrandPurpleColor}" Opacity="0.55" />
        </Border.BorderBrush>
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="vm:GlobalViewModel.OpenWebpageCommand" CommandParameter="https://rsware.store/" />
        </Border.InputBindings>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="pack://application:,,,/Resources/RswareLogo.png" Width="34" Height="34"
                   VerticalAlignment="Center" Margin="0,0,14,0" RenderOptions.BitmapScalingMode="HighQuality" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Get your tools at rsware.store" />
                    <Border Margin="10,0,0,0" Padding="7,2" CornerRadius="4" VerticalAlignment="Center"
                            Background="{StaticResource BrandPurpleBrush}">
                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="White" Text="FIRST BUYERS 5% OFF" />
                    </Border>
                </StackPanel>
                <TextBlock FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Executors: " /><Run Text="Potassium · Volt     " /><Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Externals: " /><Run Text="Severe · Matrix Hub" />
                </TextBlock>
            </StackPanel>

            <ui:Button Grid.Column="2" VerticalAlignment="Center" Margin="14,0,0,0" Appearance="Primary"
                       Icon="ShoppingBag24" Content="Shop now"
                       Command="vm:GlobalViewModel.OpenWebpageCommand" CommandParameter="https://rsware.store/" />
        </Grid>
    </Border>
</UserControl>
