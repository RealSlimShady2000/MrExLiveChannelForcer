<base:WpfUiWindow x:Class="MrExStrap.UI.Elements.Dialogs.HealthCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:MrExStrap.UI.Elements.Base"
        mc:Ignorable="d"
        Width="720"
        Height="560"
        Title="Health check"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Padding="8" ShowMinimize="False" CanMaximize="False"
                     Title="Health check" />

        <Border Grid.Row="1" Padding="16,12">
            <StackPanel>
                <TextBlock Text="MrExBloxstrap health check" FontWeight="SemiBold" FontSize="16" />
                <TextBlock x:Name="SummaryTextBlock" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Running..." />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="16,0,16,12" Padding="12" CornerRadius="4"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="ResultsTextBox"
                         FontFamily="Consolas" FontSize="12"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="Running..." />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3" Padding="15" Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="RerunButton" Icon="ArrowClockwise24" Content="Re-run"
                           Margin="0,0,12,0" Click="RerunButton_Click" />
                <ui:Button x:Name="CopyButton" Icon="Copy24" Content="Copy to clipboard"
                           Margin="0,0,12,0" Click="CopyButton_Click" />
                <ui:Button x:Name="SaveButton" Icon="Save24" Content="Save to file" Appearance="Primary"
                           Margin="0,0,12,0" Click="SaveButton_Click" />
                <ui:Button x:Name="CloseButton" Content="Close"
                           Click="CloseButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</base:WpfUiWindow>
