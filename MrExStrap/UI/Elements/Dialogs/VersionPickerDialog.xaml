<base:WpfUiWindow x:Class="ExploitStrap.UI.Elements.Dialogs.VersionPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:ExploitStrap.UI.Elements.Base"
        xmlns:models="clr-namespace:ExploitStrap.UI.ViewModels.Dialogs"
        mc:Ignorable="d"
        Title="Pick a version"
        MinWidth="0"
        MinHeight="0"
        Width="620"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=models:VersionPickerViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Padding="8"
                     Title="Pick a version"
                     ShowMinimize="False" ShowMaximize="False"
                     CanMaximize="False"
                     KeyboardNavigation.TabNavigation="None"
                     Icon="pack://application:,,,/ExploitStrap.ico" />

        <TextBlock Grid.Row="1" Margin="16,12,16,8" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Choose which version profile to launch Roblox on. The selected profile becomes the active one for future launches too." />

        <ScrollViewer Grid.Row="2" MaxHeight="380" Margin="16,0,16,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Tiles, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="170" ItemHeight="210" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="6" Padding="0" CornerRadius="6"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="#3B82F6" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding Id}" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" HorizontalAlignment="Right" Margin="0,6,6,0"
                                        Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="#3B82F6" FontSize="18" />
                                </Border>

                                <Border Grid.Row="1" Width="80" Height="80" Margin="0,4,0,0"
                                        HorizontalAlignment="Center" CornerRadius="6" Background="#000000">
                                    <Grid>
                                        <Image Source="{Binding Logo, Mode=OneWay}"
                                               Stretch="Uniform" Margin="6"
                                               Visibility="{Binding HasLogo, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                        <TextBlock Text="{Binding LetterPlaceholder}"
                                                   Foreground="White" FontWeight="Bold" FontSize="36"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding NoLogo, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                    </Grid>
                                </Border>

                                <TextBlock Grid.Row="2" Margin="8,8,8,0" HorizontalAlignment="Center"
                                           Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Row="3" Margin="8,2,8,6" HorizontalAlignment="Center"
                                           Text="{Binding DisplayHash, Mode=OneTime}"
                                           FontFamily="Consolas" FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Padding="14" Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button MinWidth="100" Content="Cancel" Command="{Binding CancelCommand, Mode=OneTime}" />
                <ui:Button MinWidth="120" Margin="8,0,0,0" Icon="Play24" Content="Launch"
                           Appearance="Primary"
                           IsEnabled="{Binding CanLaunch, Mode=OneWay}"
                           Command="{Binding LaunchCommand, Mode=OneTime}" />
            </StackPanel>
        </Border>
    </Grid>

    <base:WpfUiWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </base:WpfUiWindow.Resources>
</base:WpfUiWindow>
