<base:WpfUiWindow x:Class="ExploitStrap.UI.Elements.Dialogs.AddVersionProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:ExploitStrap.UI.Elements.Base"
        xmlns:models="clr-namespace:ExploitStrap.UI.ViewModels.Dialogs"
        mc:Ignorable="d"
        Title="Add a version profile"
        Width="540"
        MinHeight="0"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=models:AddVersionProfileViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Padding="8"
                     Title="Add a version profile"
                     ShowMinimize="False" ShowMaximize="False"
                     CanMaximize="False"
                     KeyboardNavigation.TabNavigation="None"
                     Icon="pack://application:,,,/ExploitStrap.ico" />

        <StackPanel Grid.Row="1" Margin="16">
            <TextBlock Text="From an executor (recommended)" FontWeight="SemiBold" FontSize="14" />
            <TextBlock Margin="0,2,0,8" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Pick your executor and the matching Roblox build gets pinned automatically." />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Exploits, Mode=OneWay}"
                          SelectedItem="{Binding SelectedExploit, Mode=TwoWay}"
                          IsEnabled="{Binding IsNotLoadingExploits, Mode=OneWay}"
                          MaxDropDownHeight="240">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding RbxVersion}" Margin="12,0,0,0"
                                           FontFamily="Consolas" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ui:Button Grid.Column="1" Margin="8,0,0,0" Icon="ArrowClockwise24" Content="Refresh"
                           Command="{Binding RefreshExploitsCommand, Mode=OneTime}"
                           IsEnabled="{Binding IsNotLoadingExploits, Mode=OneWay}" />
            </Grid>

            <Separator Margin="0,16,0,16" />

            <TextBlock Text="Or enter manually" FontWeight="SemiBold" FontSize="14" />
            <TextBlock Margin="0,2,0,8" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Useful when you know a specific Roblox version hash you want to pin." />

            <TextBlock Margin="0,2,0,2" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Profile name" />
            <TextBox Padding="8,5" Text="{Binding ProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Margin="0,8,0,2" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Version hash" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Padding="8,5"
                         FontFamily="Consolas"
                         Text="{Binding VersionHash, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ui:Button Grid.Column="1" Margin="8,0,0,0" Icon="CheckmarkCircle24" Content="Verify"
                           Command="{Binding VerifyCommand, Mode=OneTime}"
                           IsEnabled="{Binding IsNotVerifying, Mode=OneWay}" />
            </Grid>

            <Border Margin="0,10,0,0" Padding="10,6" CornerRadius="4"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,2"
                    Visibility="{Binding HasStatus, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Text="{Binding StatusMessage, Mode=OneWay}" />
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Padding="14" Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button MinWidth="100" Content="Cancel" Command="{Binding CancelCommand, Mode=OneTime}" />
                <ui:Button MinWidth="100" Margin="8,0,0,0" Content="Create" Appearance="Primary"
                           Command="{Binding CreateCommand, Mode=OneTime}" />
            </StackPanel>
        </Border>
    </Grid>

    <base:WpfUiWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </base:WpfUiWindow.Resources>
</base:WpfUiWindow>
