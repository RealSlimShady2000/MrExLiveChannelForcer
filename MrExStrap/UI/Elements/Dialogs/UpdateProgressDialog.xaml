<base:WpfUiWindow x:Class="ExploitStrap.UI.Elements.Dialogs.UpdateProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:ExploitStrap.UI.Elements.Base"
        xmlns:local="clr-namespace:ExploitStrap.UI.Elements.Dialogs"
        mc:Ignorable="d"
        Title="Updating ExploitStrap"
        MinWidth="0"
        MinHeight="0"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen"
        Closing="WpfUiWindow_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Padding="8"
                     Title="Updating ExploitStrap"
                     ShowMinimize="False" ShowMaximize="False" ShowClose="False"
                     CanMaximize="False"
                     KeyboardNavigation.TabNavigation="None"
                     Icon="pack://application:,,,/ExploitStrap.ico" />

        <StackPanel Grid.Row="1" Margin="20,16,20,20">
            <TextBlock x:Name="HeaderText"
                       Text="Downloading update…"
                       FontSize="14" FontWeight="SemiBold" />
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Please wait. ExploitStrap will restart and reopen the menu when the download finishes." />

            <ProgressBar x:Name="ProgressBar"
                         Margin="0,16,0,0"
                         Height="6"
                         Minimum="0" Maximum="100"
                         IsIndeterminate="True" />

            <TextBlock x:Name="StatusText"
                       Margin="0,8,0,0"
                       FontSize="11" FontFamily="Consolas"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="Connecting…" />
        </StackPanel>
    </Grid>
</base:WpfUiWindow>
