<ui:UiPage x:Class="ExploitStrap.UI.Elements.Settings.Pages.FastFlagsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:ExploitStrap.UI.ViewModels"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:resources="clr-namespace:ExploitStrap.Resources"
      xmlns:controls="clr-namespace:ExploitStrap.UI.Elements.Controls"
      mc:Ignorable="d"
      d:DesignHeight="1500" d:DesignWidth="800"
      Title="FastFlagsPage"
      Scrollable="True"
      Loaded="Page_Loaded">
    <StackPanel Margin="0,0,14,14">
        <controls:StorePromoBanner />
        <TextBlock Margin="0,0,0,8" Text="{x:Static resources:Strings.Menu_FastFlags_Description}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <!-- ===== Per-profile selector ===== -->
        <TextBlock Margin="0,8,0,4" Text="Editing flags for" FontWeight="SemiBold" />
        <ComboBox x:Name="ProfileSelector" MinWidth="280" Padding="10,5,10,5"
                  DisplayMemberPath="Name"
                  MaxDropDownHeight="240"
                  SelectionChanged="ProfileSelector_SelectionChanged" />
        <TextBlock Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="Each Versions Manager profile keeps its own fast flags. The flags shown here belong to the profile selected above; the profile you actually launch is what gets applied to Roblox." />

        <controls:OptionControl Margin="0,16,0,0"
            Header="{x:Static resources:Strings.Menu_FastFlags_ManagerEnabled_Title}"
            Description="{x:Static resources:Strings.Menu_FastFlags_ManagerEnabled_Description}">
            <ui:ToggleSwitch IsChecked="{Binding UseFastFlagManager, Mode=TwoWay}" />
        </controls:OptionControl>

        <!-- ===== Presets ===== -->
        <TextBlock Text="{x:Static resources:Strings.Common_Presets}" FontSize="20" FontWeight="Medium" Margin="0,16,0,0" />

        <TextBlock Text="{x:Static resources:Strings.Menu_FastFlags_Presets_Categories_Rendering}" FontSize="16" FontWeight="Medium" Margin="0,16,0,0" />
        <controls:MarkdownTextBlock MarkdownText="{Binding Source={x:Static resources:Strings.Menu_FastFlags_Presets_D3DExclusiveFullscreenInfo}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://bloxstraplabs.com/wiki/features/engine-settings/#exclusive-fullscreen'}"  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <controls:OptionControl
            Header="{x:Static resources:Strings.Menu_FastFlags_Presets_MSAA_Title}">
            <ComboBox Margin="5,0,0,0" Padding="10,5,10,5" Width="200" ItemsSource="{Binding MSAALevels.Keys, Mode=OneTime}" Text="{Binding SelectedMSAALevel, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </controls:OptionControl>

        <controls:OptionControl
            Header="{x:Static resources:Strings.Menu_FastFlags_Presets_FixDisplayScaling_Title}"
            Description="{x:Static resources:Strings.Menu_FastFlags_Presets_FixDisplayScaling_Description}"
            HelpLink="https://bloxstraplabs.com/wiki/features/engine-settings/#preserving-rendering-quality">
            <ui:ToggleSwitch IsChecked="{Binding FixDisplayScaling, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="{x:Static resources:Strings.Menu_FastFlags_Presets_TextureQuality_Title}">
            <ComboBox Margin="5,0,0,0" Padding="10,5,10,5" Width="200" ItemsSource="{Binding TextureQualities.Keys, Mode=OneTime}" Text="{Binding SelectedTextureQuality, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </controls:OptionControl>

        <controls:OptionControl
            Header="Max framerate (FPS unlocker)"
            Description="Removes Roblox's 60 FPS cap by setting the DFIntTaskSchedulerTargetFps engine flag before launch — the safe config method Bloxstrap and Fishstrap use, not a memory patcher like rbxfpsunlocker. Pick your monitor's refresh rate or Unlimited. Whether Roblox honours it can change with engine updates.">
            <ComboBox Margin="5,0,0,0" Padding="10,5,10,5" Width="200" ItemsSource="{Binding FramerateLimits.Keys, Mode=OneTime}" Text="{Binding SelectedFramerateLimit, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </controls:OptionControl>

        <controls:OptionControl
            Margin="0,24,0,0"
            Header="{x:Static resources:Strings.Menu_FastFlags_Reset_Title}">
            <ui:ToggleSwitch IsChecked="{Binding ResetConfiguration, Mode=TwoWay}" />
        </controls:OptionControl>

        <!-- ===== Raw editor ===== -->
        <TextBlock Margin="0,28,0,2" Text="{x:Static resources:Strings.Menu_FastFlagEditor_Title}" FontSize="20" FontWeight="Medium" />
        <TextBlock Margin="0,0,0,2" Text="{x:Static resources:Strings.Menu_FastFlagEditor_Description}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <controls:MarkdownTextBlock TextWrapping="Wrap" FontSize="14" FontWeight="Bold" Margin="0,0,0,12" MarkdownText="{Binding Source={x:Static resources:Strings.Menu_FastFlagEditor_AllowlistInformation}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://devforum.roblox.com/t/allowlist-for-local-client-configuration-via-fast-flags/3966569'}"  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <!-- Bordered wrapped panels instead of ui:InfoBar: InfoBar's Message TextBlock
             doesn't wrap, so the long multi-line banner text was clipped on the right
             (user report 2026-06-01). These wrap and grow with the page width. -->
        <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="4"
                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCautionBrush}" BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Top" />
                <StackPanel MaxWidth="640">
                    <TextBlock FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"
                               Text="{x:Static resources:Strings.Menu_FastFlagEditor_BannerTitle}" />
                    <TextBlock Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{x:Static resources:Strings.Menu_FastFlagEditor_BannerText}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="4"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorAttentionBrush}" BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Info24" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Top" />
                <StackPanel MaxWidth="640">
                    <TextBlock FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"
                               Text="Will I face consequences for using flags that aren't on the allowlist?" />
                    <TextBlock Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="No. Fast Flags that aren't on Roblox's allowlist are simply ignored. No action is taken against you for trying to set one, it just won't do anything." />
                </StackPanel>
            </StackPanel>
        </Border>

        <Expander Margin="0,0,0,16" Header="What Fast Flags are currently on Roblox's allowlist?">
            <StackPanel Margin="4,8,4,4">
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,10"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Roblox re-evaluates this allowlist regularly and can change it at any time without warning. This list being here is no guarantee a flag stays allowed. Anything not on it has no effect on the Roblox player." />

                <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,4,0,2" Text="Geometry" />
                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    DFIntCSGLevelOfDetailSwitchingDistance<LineBreak />
                    DFIntCSGLevelOfDetailSwitchingDistanceL12<LineBreak />
                    DFIntCSGLevelOfDetailSwitchingDistanceL23<LineBreak />
                    DFIntCSGLevelOfDetailSwitchingDistanceL34
                </TextBlock>

                <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,10,0,2" Text="Rendering" />
                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    FFlagHandleAltEnterFullscreenManually<LineBreak />
                    DFFlagTextureQualityOverrideEnabled<LineBreak />
                    DFIntTextureQualityOverride<LineBreak />
                    FIntDebugForceMSAASamples<LineBreak />
                    DFFlagDisableDPIScale<LineBreak />
                    FFlagDebugGraphicsPreferD3D11<LineBreak />
                    FFlagDebugSkyGray<LineBreak />
                    DFFlagDebugPauseVoxelizer<LineBreak />
                    DFIntDebugFRMQualityLevelOverride<LineBreak />
                    FIntFRMMaxGrassDistance<LineBreak />
                    FIntFRMMinGrassDistance<LineBreak />
                    FFlagDebugGraphicsPreferVulkan<LineBreak />
                    FFlagDebugGraphicsPreferOpenGL
                </TextBlock>

                <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,10,0,2" Text="User Interface" />
                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    FIntGrassMovementReducedMotionFactor
                </TextBlock>
            </StackPanel>
        </Expander>

        <WrapPanel Orientation="Horizontal">
            <ui:Button Icon="Add28" Content="{x:Static resources:Strings.Menu_FastFlagEditor_AddNew}" Click="AddButton_Click" Margin="0,0,12,16" />
            <ui:Button Icon="Delete48" Content="{x:Static resources:Strings.Menu_FastFlagEditor_DeleteSelected}" Click="DeleteButton_Click" Appearance="Danger"  Margin="0,0,12,16">
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=DataGrid, Path=SelectedItems.Count}" Value="0">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
            <ToggleButton x:Name="TogglePresetsButton"  Content="{x:Static resources:Strings.Menu_FastFlagEditor_ShowPresetFlags}" Click="ToggleButton_Click"  Margin="0,0,12,16" />
            <ui:Button Icon="ArrowExportRtl24" Content="{x:Static resources:Strings.Menu_FastFlagEditor_ExportJson}" Click="ExportJSONButton_Click" Margin="0,0,12,16" />
        </WrapPanel>

        <ui:TextBox x:Name="SearchTextBox" Margin="0,0,0,16" Icon="Search32" PlaceholderText="{x:Static resources:Strings.Menu_FastFlagEditor_Search}" TextChanged="SearchTextBox_TextChanged" />

        <DataGrid Name="DataGrid" MaxHeight="460" HeadersVisibility="Column" GridLinesVisibility="Horizontal" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CellEditEnding="DataGrid_CellEditEnding" CanUserReorderColumns="False">
            <DataGrid.Style>
                <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </DataGrid.Style>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Padding" Value="8,0,8,0" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource TextOnAccentFillColorPrimary}" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource SystemAccentColorSecondary}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}" Padding="6,0,6,0">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static resources:Strings.Common_Name}" Binding="{Binding Name}" />
                <DataGridTextColumn Header="{x:Static resources:Strings.Common_Value}" Binding="{Binding Value}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</ui:UiPage>
