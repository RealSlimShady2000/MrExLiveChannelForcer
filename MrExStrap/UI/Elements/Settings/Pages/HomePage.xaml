<ui:UiPage x:Class="ExploitStrap.UI.Elements.Settings.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:models="clr-namespace:ExploitStrap.UI.ViewModels"
      xmlns:controls="clr-namespace:ExploitStrap.UI.Elements.Controls"
      mc:Ignorable="d"
      d:DesignHeight="620" d:DesignWidth="780"
      Title="HomePage"
      Scrollable="True">
    <Grid Margin="0,8,14,14">
        <StackPanel MaxWidth="660" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,28,0,0">

            <!-- Brand wordmark -->
            <Image Source="pack://application:,,,/Resources/ExploitStrap.png"
                   Width="380" HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Effect="{StaticResource BrandGlowEffect}" />

            <TextBlock Text="The Roblox launcher built for executor and exploit users."
                       HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="14"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- Gradient divider -->
            <Border Height="3" Width="200" CornerRadius="2" Margin="0,18,0,0"
                    Background="{StaticResource BrandGradientBrush}" />

            <!-- Status tiles -->
            <UniformGrid Columns="3" Margin="0,22,0,0">
                <Border Style="{StaticResource HomeTile}">
                    <StackPanel>
                        <TextBlock Text="CHANNEL" Style="{StaticResource BrandSectionHeader}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding ChannelStatus}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandGreenBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HomeTile}">
                    <StackPanel>
                        <TextBlock Text="VERSION" Style="{StaticResource BrandSectionHeader}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding Version}" FontSize="18" FontWeight="SemiBold"
                                   Style="{StaticResource BrandMono}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HomeTile}">
                    <StackPanel>
                        <TextBlock Text="ACTIVE PROFILE" Style="{StaticResource BrandSectionHeader}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding ActiveProfileName}" FontSize="18" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ExecutorTitle}" FontSize="12" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasExecutor}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Primary launch CTA — reuses the settings window's Save & Launch command -->
            <ui:Button Margin="6,28,6,0" Height="50" HorizontalAlignment="Stretch"
                       Appearance="Primary" Icon="Play24" FontSize="16"
                       Content="Save and launch Roblox"
                       Command="{Binding DataContext.SaveAndLaunchCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />

            <!-- Store plug: rsware.store -->
            <controls:StorePromoBanner Margin="6,18,6,0" />

            <TextBlock HorizontalAlignment="Center" Margin="0,14,0,0" FontSize="12"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="LIVE channel is re-locked on every launch." />
        </StackPanel>
    </Grid>
</ui:UiPage>
