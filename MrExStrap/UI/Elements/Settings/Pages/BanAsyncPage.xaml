<ui:UiPage x:Class="MrExStrap.UI.Elements.Settings.Pages.BanAsyncPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:MrExStrap.UI.Elements.Controls"
      xmlns:models="clr-namespace:MrExStrap.UI.ViewModels.Settings"
      xmlns:vmroot="clr-namespace:MrExStrap.UI.ViewModels"
      d:DataContext="{d:DesignInstance Type=models:BanAsyncViewModel}"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="BanAsyncPage"
      Scrollable="True">

    <StackPanel Margin="0,0,14,14">

        <TextBlock Margin="0,0,0,4" Text="BanAsync tools" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Margin="0,0,0,12" TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Trace cleanup, network adapter MAC spoofing, and MachineGuid randomization. Aimed at the same surface Roblox's BanAsync detection looks at. Use at your own risk on your own machine." />

        <!-- Elevation banner — visible when MrExBloxstrap is NOT running as administrator.
             The "Relaunch as administrator" button re-spawns the current exe with the
             runas verb so Windows pops the UAC prompt for the user. -->
        <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="4"
                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCautionBrush}"
                BorderThickness="0,0,0,2"
                Visibility="{Binding ElevationWarningVisibility, Mode=OneTime}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="Warning24" FontSize="20"
                               Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" TextWrapping="Wrap" VerticalAlignment="Center"
                           Text="{Binding ElevationStatusText, Mode=OneTime}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="12" />
                <ui:Button Grid.Column="2" Margin="12,0,0,0" MinWidth="200"
                           Icon="ShieldKeyhole24" Content="Relaunch as administrator"
                           Appearance="Primary"
                           Command="{Binding RelaunchAsAdminCommand, Mode=OneTime}" />
            </Grid>
        </Border>

        <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="4"
                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorSuccessBrush}"
                BorderThickness="0,0,0,2"
                Visibility="{Binding AdminFeaturesVisibility, Mode=OneTime}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock TextWrapping="Wrap" VerticalAlignment="Center"
                           Text="{Binding ElevationStatusText, Mode=OneTime}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- ===== Trace cleanup ===== -->
        <TextBlock Margin="0,10,0,4" Text="Clean Roblox traces" FontSize="15" FontWeight="SemiBold" />
        <TextBlock Margin="0,0,0,4" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Closes Roblox, wipes local caches, logs, prefetch entries, and HKCU registry, so the next launch looks like a fresh client to BanAsync. MrExBloxstrap's own settings stay untouched." />

        <controls:OptionControl
            Header="Preserve in-game settings"
            Description="Backs up GlobalBasicSettings_*.xml before the wipe and restores it after, so your camera/graphics/keybind choices survive.">
            <ui:ToggleSwitch IsChecked="{Binding PreserveInGameSettings, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Preserve vanilla Roblox FastFlags"
            Description="Holds onto ClientAppSettings.json / ClientSettings.json across the wipe. If you only use MrExBloxstrap-managed FastFlags this doesn't matter — those live elsewhere and are never deleted.">
            <ui:ToggleSwitch IsChecked="{Binding PreserveFastFlags, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Include Roblox Studio folders"
            Description="Also wipe Studio caches. Off by default since the cleanup is aimed at the player.">
            <ui:ToggleSwitch IsChecked="{Binding IncludeStudioFolders, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Also wipe downloaded Roblox installs (Versions)"
            Description="Deletes MrExBloxstrap's Versions folder — every downloaded Roblox client across all profiles. OFF by default: this forces a full re-download on the next launch and does NOT help with ban traces (the Roblox binaries aren't unique to you). Turn it on only if you want a completely clean slate.">
            <ui:ToggleSwitch IsChecked="{Binding CleanMrExVersions, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Also clear Roblox browser cookies"
            Description="Wipes only the cookies that roblox.com and rbxcdn.com have stored in any browsers you have installed (Chrome, Edge, Firefox, Brave, Opera, Vivaldi). Your other site cookies (Gmail, banking, Discord, everything else) are NOT touched. Close your browsers first — cookie files are locked while the browser is open and locked ones get skipped with a warning in the log.">
            <ui:ToggleSwitch IsChecked="{Binding ClearBrowserCookies, Mode=TwoWay}" />
        </controls:OptionControl>

        <ui:Button Margin="0,10,0,0" MinWidth="180" Icon="Broom24" Content="Clean traces now"
                   Appearance="Danger"
                   Command="{Binding CleanTracesCommand, Mode=OneTime}" />

        <!-- ===== MAC spoofing ===== -->
        <TextBlock Margin="0,24,0,4" Text="MAC address spoofing" FontSize="15" FontWeight="SemiBold" />
        <TextBlock Margin="0,0,0,4" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Writes a NetworkAddress override under HKLM and bounces the adapter so the new MAC takes effect. Virtual and VPN adapters are filtered out. Needs administrator privileges." />

        <StackPanel>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Detected adapters" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ui:Button Grid.Column="1" Icon="ArrowSync24" Content="Refresh"
                           Command="{Binding RefreshAdaptersCommand, Mode=OneTime}" />
            </Grid>

            <controls:OptionControl Margin="0,8,0,0"
                Header="Advanced mode"
                Description="Off: spoof every detected adapter with a random MAC. On: pick one adapter and (optionally) type a specific MAC.">
                <ui:ToggleSwitch IsChecked="{Binding AdvancedMode, Mode=TwoWay}" />
            </controls:OptionControl>

            <controls:OptionControl Margin="0,8,0,0"
                Header="OUI mirror"
                Description="Keep the original vendor prefix (first 3 bytes) and only randomize the last 3. Spoofed MAC still looks like it's from the same vendor as your real card.">
                <ui:ToggleSwitch IsChecked="{Binding OuiMirror, Mode=TwoWay}" />
            </controls:OptionControl>

            <controls:OptionControl Margin="0,8,0,0"
                Header="Refresh DHCP after spoof (optional)"
                Description="Not required for BanAsync. The disable/enable cycle MrExBloxstrap already runs on the adapter releases your DHCP lease cleanly, so this is purely an optional belt-and-suspenders pass for overly paranoid users. Side effects if you turn it on: brief network outage, dropped VPN/voice calls, possible captive-portal re-trigger.">
                <ui:ToggleSwitch IsChecked="{Binding DhcpRefreshAfterSpoof, Mode=TwoWay}" />
            </controls:OptionControl>

            <controls:OptionControl Margin="0,8,0,0"
                Header="Persistent (keep MAC change after MrExBloxstrap closes)"
                Description="Default ON. The spoofed MAC is written to the Windows registry under HKLM and stays applied across MrExBloxstrap closing, being uninstalled, AND reboots — the same way Technitium MAC Address Changer does it. Turn OFF if you want MrExBloxstrap to clear the registry override on its own exit (the MAC still stays active for the current Windows session and reverts on next reboot). Either way, the Revert MAC button works.">
                <ui:ToggleSwitch IsChecked="{Binding Persistent, Mode=TwoWay}" />
            </controls:OptionControl>

            <!-- Advanced-only controls -->
            <StackPanel Margin="0,8,0,0" Visibility="{Binding AdvancedVisibility, Mode=OneWay}">

                <TextBlock Margin="0,0,0,4" Text="Pick adapter" FontWeight="SemiBold" />
                <ComboBox MinWidth="320" Padding="10,5,10,5"
                          ItemsSource="{Binding Adapters, Mode=OneWay}"
                          SelectedItem="{Binding SelectedAdapter, Mode=TwoWay}"
                          DisplayMemberPath="DisplayLine"
                          MaxDropDownHeight="240" />

                <TextBlock Margin="0,8,0,0" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding CurrentMacFormatted, Mode=OneWay, StringFormat='Current MAC: {0}'}" />

                <TextBlock Margin="0,2,0,0" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding OriginalMacFormatted, Mode=OneWay, StringFormat='Original MAC: {0}'}" />

                <TextBlock Margin="0,12,0,4" Text="Custom MAC (leave blank to use a random one)" FontWeight="SemiBold" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Padding="8,5"
                             Text="{Binding CustomMac, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button Grid.Column="1" Margin="8,0,0,0" Icon="ArrowShuffle24" Content="Shuffle"
                               Command="{Binding ShuffleMacCommand, Mode=OneTime}" />
                </Grid>
            </StackPanel>

            <!-- Simple-mode hint -->
            <Border Margin="0,8,0,0" Padding="12,8" CornerRadius="4"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="{Binding SimpleVisibility, Mode=OneWay}">
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Simple mode will randomize every detected adapter's MAC in one pass. Toggle Advanced mode above to pick a specific adapter or type a MAC yourself." />
            </Border>

            <!-- Action buttons — admin-only. ToolTipService.ShowOnDisabled keeps the
                 tooltip visible when greyed out so the user understands WHY they can't
                 click instead of staring at a dead button. -->
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                        IsEnabled="{Binding IsElevated, Mode=OneTime}">
                <ui:Button MinWidth="140" Icon="Connector24" Content="Spoof MAC"
                           Appearance="Primary"
                           Command="{Binding SpoofCommand, Mode=OneTime}"
                           ToolTipService.ShowOnDisabled="True"
                           ToolTip="Writes the new MAC to the adapter's NetworkAddress registry value. Requires administrator privileges — use the 'Relaunch as administrator' button at the top of this page if disabled." />
                <ui:Button MinWidth="140" Margin="8,0,0,0" Icon="ArrowUndo24" Content="Revert MAC"
                           Appearance="Danger"
                           Command="{Binding RevertCommand, Mode=OneTime}"
                           ToolTipService.ShowOnDisabled="True"
                           ToolTip="Clears the registry MAC override so Windows uses the hardware MAC again. Requires administrator privileges." />
            </StackPanel>

        </StackPanel>

        <!-- ===== MachineGuid ===== -->
        <TextBlock Margin="0,24,0,4" Text="MachineGuid (optional)" FontSize="15" FontWeight="SemiBold" />
        <TextBlock Margin="0,0,0,8" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Same story as DHCP refresh — not required for BanAsync. This is an optional extra for users being overly paranoid about every identifier on their PC. Keep it as a tool in case you need it." />

        <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="4"
                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCautionBrush}"
                BorderThickness="0,0,0,2">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" FontSize="13" Text="What is MachineGuid?" />
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12"
                           Text="A unique ID Windows wrote to your install the day it was first set up. Some apps use it as a quiet 'is this the same PC?' check." />

                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" FontSize="13" Text="Pros — what randomizing it gets you" />
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12"
                           Text="One more identifier swapped out. Anything keying off MachineGuid sees a fresh PC." />

                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" FontSize="13" Text="Cons — what could break" />
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12"
                           Text="Microsoft Office can lose activation. Some paid apps tied to your machine will ask for reactivation. Windows telemetry pairing resets (harmless). MrExBloxstrap saves your original value the first time you randomize so you can restore it from this page at any point." />
            </StackPanel>
        </Border>

        <controls:OptionControl
            Header="I understand the risk"
            Description="Tick this to unlock the Randomize / Restore buttons. Stops you from changing MachineGuid by accident.">
            <ui:ToggleSwitch IsChecked="{Binding MachineGuidAcknowledged, Mode=TwoWay}" />
        </controls:OptionControl>

        <TextBlock Margin="0,8,0,0" FontSize="12" FontFamily="Consolas"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="{Binding CurrentMachineGuid, Mode=OneWay, StringFormat='Current MachineGuid: {0}'}" />
        <TextBlock Margin="0,2,0,0" FontSize="12" FontFamily="Consolas"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="{Binding MachineGuidBackupText, Mode=OneWay}" />

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                    IsEnabled="{Binding MachineGuidActionsEnabled, Mode=OneWay}">
            <ui:Button MinWidth="180" Icon="Sparkle24" Content="Randomize MachineGuid"
                       Appearance="Primary"
                       Command="{Binding RandomizeMachineGuidCommand, Mode=OneTime}"
                       ToolTipService.ShowOnDisabled="True"
                       ToolTip="Writes a new random GUID to HKLM\SOFTWARE\Microsoft\Cryptography\MachineGuid. Requires administrator privileges AND the 'I understand the risk' toggle above." />
            <ui:Button MinWidth="180" Margin="8,0,0,0" Icon="ArrowUndo24" Content="Restore original"
                       Command="{Binding RestoreMachineGuidCommand, Mode=OneTime}"
                       ToolTipService.ShowOnDisabled="True"
                       ToolTip="Writes the original MachineGuid (saved on the first randomize) back to the registry. Requires administrator privileges AND the 'I understand the risk' toggle above." />
        </StackPanel>

        <!-- ===== Activity log ===== -->
        <TextBlock Margin="0,24,0,4" Text="Activity log" FontSize="15" FontWeight="SemiBold" />
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Per-action progress and errors. Cleared on page reload." />
            <ui:Button Grid.Column="1" Icon="EraserSmall24" Content="Clear"
                       Command="{Binding ClearLogCommand, Mode=OneTime}" />
        </Grid>
        <Border x:Name="ActivityLogBorder" Padding="0" CornerRadius="4"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
            <ListBox x:Name="ActivityLogList" MinHeight="160" MaxHeight="240" Background="Transparent" BorderThickness="0"
                     FontFamily="Consolas" FontSize="12"
                     ItemsSource="{Binding ActivityLog, Mode=OneWay}"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Border>

        <TextBlock Margin="0,12,0,0" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap">
            <Run>BanAsync feature set inspired by</Run>
            <Hyperlink Command="vmroot:GlobalViewModel.OpenWebpageCommand"
                       CommandParameter="https://github.com/focat69/rblxswap/">focat69's rblxswap</Hyperlink>
            <Run>. Implementation is original.</Run>
        </TextBlock>

    </StackPanel>
</ui:UiPage>
